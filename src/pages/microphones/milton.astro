---
import BaseLayout from '../../layouts/BaseLayout.astro';

const priceValidUntil = new Date(Date.now() + 365 * 24 * 60 * 60 * 1000).toISOString().split('T')[0];

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'Milton Condenser Microphone',
  description: 'A hand-built large-diaphragm condenser microphone with vintage character, clarity, and warmth. For acoustic instruments, vocals, and live performance.',
  image: 'https://www.molinellomusic.com/images/milton/milton-on-stand.jpg',
  brand: {
    '@type': 'Brand',
    name: 'Molinello Music',
  },
  offers: {
    '@type': 'Offer',
    price: '449.00',
    priceCurrency: 'USD',
    availability: 'https://schema.org/InStock',
    url: 'https://www.molinellomusic.com/microphones/milton',
    priceValidUntil,
    hasMerchantReturnPolicy: {
      '@type': 'MerchantReturnPolicy',
      applicableCountry: 'US',
      returnPolicyCategory: 'https://schema.org/MerchantReturnFiniteReturnWindow',
      merchantReturnDays: 30,
      returnMethod: 'https://schema.org/ReturnByMail',
      returnFees: 'https://schema.org/ReturnShippingFees',
    },
    shippingDetails: {
      '@type': 'OfferShippingDetails',
      shippingRate: {
        '@type': 'MonetaryAmount',
        value: '0',
        currency: 'USD',
      },
      shippingDestination: {
        '@type': 'DefinedRegion',
        addressCountry: 'US',
      },
      deliveryTime: {
        '@type': 'ShippingDeliveryTime',
        handlingTime: {
          '@type': 'QuantitativeValue',
          minValue: 3,
          maxValue: 14,
          unitCode: 'DAY',
        },
        transitTime: {
          '@type': 'QuantitativeValue',
          minValue: 3,
          maxValue: 7,
          unitCode: 'DAY',
        },
      },
    },
  },
};
---

<BaseLayout title="Milton - Molinello Music" description="A hand-built condenser with vintage character, clarity, and warmth. For musicians and creators." ogImage="/images/milton/milton-on-stand.jpg" structuredData={productSchema}>
  <!-- Hero -->
  <section class="bg-brand-dark text-white py-16 md:py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <h1 class="font-heading font-extrabold text-5xl md:text-6xl mb-4">Milton</h1>
      <p class="text-xl md:text-2xl text-brand-orange font-heading mb-2">A Hand-Built Condenser with Vintage Character, Clarity, and Warmth</p>
      <p class="text-gray-400 max-w-2xl mx-auto">
        For musicians, creators, and engineers who want boutique looks and sound without boutique prices.
      </p>
    </div>
  </section>

  <!-- Main product image + value prop -->
  <section class="py-16 md:py-24">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="md:flex gap-12 items-center">
        <div class="md:w-1/2 mb-8 md:mb-0">
          <img src="/images/milton/milton-on-stand.jpg" alt="Milton microphone on stand" class="rounded-xl shadow-lg w-full max-w-sm mx-auto" />
        </div>
        <div class="md:w-1/2">
          <h2 class="font-heading font-bold text-3xl mb-4">For Creators Who Want Their Recordings to <em>Feel</em> Like Music</h2>
          <p class="text-gray-600 text-lg mb-6 leading-relaxed">
            There are thousands of generic condensers. Most look the same&mdash;no character, too hyped in the high frequencies, and generally not great. Milton is natural, clean, and captures the dimension of your acoustic instrument. This is for musicians who want to have an excellent <em>vibe</em> in addition to warm and pure sound.
          </p>
          <!-- Pricing -->
          <div class="bg-brand-warm rounded-xl p-6 mb-6">
            <p class="text-gray-500 line-through text-lg">$499</p>
            <p class="font-heading font-extrabold text-4xl text-brand-dark mb-1">$449</p>
            <p class="text-sm text-gray-500 mb-3">with free shipping</p>
            <a href="https://buy.stripe.com/9B6bJ1eCVbZL9M33eA8og0j" target="_blank" rel="noopener noreferrer" class="inline-block bg-brand-orange text-white font-heading font-bold px-8 py-3 rounded-lg hover:bg-orange-600 transition-colors w-full text-center">
              Buy Now
            </a>
          </div>
          <p class="text-sm text-gray-500">
            Or, if the "Buy Now" mics sell out, <a href="https://buy.stripe.com/aFaeVd66pbZL7DVdTe8og0c" target="_blank" rel="noopener noreferrer" class="text-brand-orange hover:underline">reserve a build slot</a>.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Sound characteristics -->
  <section class="py-16 md:py-24 bg-brand-warm">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <div class="md:flex gap-12 items-center">
        <div class="md:w-1/2 mb-8 md:mb-0">
          <h2 class="font-heading font-bold text-3xl mb-6">Warm Where Cheap Condensers Are Harsh</h2>
          <p class="text-gray-600 mb-4">Milton's tuning gives you:</p>
          <ul class="space-y-2 text-gray-600 mb-6">
            <li class="flex items-start gap-2"><span class="text-brand-orange font-bold mt-1">&#9679;</span> Smooth high-end without harshness</li>
            <li class="flex items-start gap-2"><span class="text-brand-orange font-bold mt-1">&#9679;</span> Detailed midrange for guitar, vocals, strings</li>
            <li class="flex items-start gap-2"><span class="text-brand-orange font-bold mt-1">&#9679;</span> Balanced low-end</li>
            <li class="flex items-start gap-2"><span class="text-brand-orange font-bold mt-1">&#9679;</span> A rounded, "musical" tone you'll want to keep hearing</li>
          </ul>
          <p class="text-gray-600 font-semibold mb-2">Use it for:</p>
          <p class="text-gray-500">Acoustic guitar, vocals, mandolin, fiddle, banjo, dobro, and other acoustic instruments and ensembles.</p>
          <p class="text-gray-700 font-heading font-semibold mt-4 italic">"Milton feels like a mic that costs three times as much."</p>
        </div>
        <div class="md:w-1/2">
          <img src="/images/milton/milton-with-guitar.jpg" alt="Milton microphone recording acoustic guitar" class="rounded-xl shadow-lg w-full" />
        </div>
      </div>
    </div>
  </section>

  <!-- Emotional appeal -->
  <section class="py-16 md:py-24">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="font-heading font-bold text-3xl mb-6">The Feeling of Hearing a Mic You Instantly Trust</h2>
      <p class="text-gray-600 text-lg leading-relaxed">
        There's a clarity that makes you want to keep recording. A tone that makes you play differently&mdash;because it inspires you back. A simplicity that lets you forget the gear and focus on your music.
      </p>
    </div>
  </section>

  <!-- Videos -->
  <section class="py-16 md:py-24 bg-brand-warm">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <h2 class="font-heading font-bold text-3xl mb-10 text-center">Hear Milton in Action</h2>
      <div class="grid md:grid-cols-2 gap-8">
        <div class="aspect-video rounded-xl overflow-hidden shadow-lg">
          <iframe src="https://www.youtube.com/embed/H71eO1fZLLs" title="Milton demo video 1" class="w-full h-full" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
        </div>
        <div class="aspect-video rounded-xl overflow-hidden shadow-lg">
          <iframe src="https://www.youtube.com/embed/3-cLx2EZ_NM" title="Milton demo video 2" class="w-full h-full" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
        </div>
      </div>
    </div>
  </section>

  <!-- Craftsmanship -->
  <section class="py-16 md:py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <div class="md:flex gap-12 items-center">
        <div class="md:w-1/2 mb-8 md:mb-0">
          <img src="/images/milton/milton-flat.jpg" alt="Milton microphone detail" class="rounded-xl shadow-lg w-full" />
        </div>
        <div class="md:w-1/2">
          <h2 class="font-heading font-bold text-3xl mb-6">Hand-Built. Individually Tested. Never Mass-Produced.</h2>
          <p class="text-gray-600 mb-4">Milton is crafted from scratch:</p>
          <ul class="space-y-2 text-gray-600 mb-6">
            <li class="flex items-start gap-2"><span class="text-brand-orange font-bold mt-1">&#9679;</span> Custom capsule tuning</li>
            <li class="flex items-start gap-2"><span class="text-brand-orange font-bold mt-1">&#9679;</span> Hand-soldered signal path</li>
            <li class="flex items-start gap-2"><span class="text-brand-orange font-bold mt-1">&#9679;</span> Built-in RFI-rejection architecture</li>
            <li class="flex items-start gap-2"><span class="text-brand-orange font-bold mt-1">&#9679;</span> Vintage-styled body and finish</li>
          </ul>
          <p class="text-gray-600 mb-2">Each mic individually tested on real acoustic instruments.</p>
          <p class="text-gray-700 font-heading font-semibold italic">This is boutique craftsmanship at a musician-friendly price.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Specs -->
  <section class="py-16 md:py-24 bg-brand-charcoal text-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <h2 class="font-heading font-bold text-3xl mb-10 text-center">Milton Technical Specifications</h2>
      <div class="grid sm:grid-cols-2 gap-x-12 gap-y-4">
        {[
          ['Capsule', 'Large diaphragm condenser (25mm/26mm)'],
          ['Pattern', 'Cardioid'],
          ['Frequency Response', '~50Hz - 20kHz'],
          ['Noise', 'Low self-noise'],
          ['Power', '48V phantom power required'],
          ['RFI Rejection', 'Modern circuitry (including cell phones)'],
          ['Includes', 'Protective hard-shell case & shock mount clip'],
          ['Weight', '0.5 lb (225g)'],
        ].map(([label, value]) => (
          <div class="border-b border-white/10 pb-3">
            <p class="text-brand-orange font-heading font-semibold text-sm">{label}</p>
            <p class="text-gray-300">{value}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Ordering -->
  <section class="py-16 md:py-24">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <h2 class="font-heading font-bold text-3xl mb-8 text-center">Built to Order, Made for Creators</h2>
      <div class="space-y-4 text-gray-600 text-lg max-w-xl mx-auto">
        <p>&#10003; Reserve with a deposit</p>
        <p>&#10003; I build your mic in the order received</p>
        <p>&#10003; Final payment when it's ready</p>
        <p>&#10003; Ships with tracking</p>
        <p>&#10003; 30-day audition period</p>
      </div>
      <p class="text-center text-gray-700 font-heading font-semibold mt-6 italic">Your mic is built by hand&mdash;not pulled off a shelf.</p>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="py-16 md:py-24 bg-brand-dark text-white text-center">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <h2 class="font-heading font-bold text-3xl mb-4">Milton Gives You Live Performance Sound You're Proud Of</h2>
      <p class="text-gray-400 mb-8">If you want a microphone with clear, natural sound, with exceptional stage presence:</p>
      <a href="https://buy.stripe.com/aFaeVd66pbZL7DVdTe8og0c" target="_blank" rel="noopener noreferrer" class="inline-block bg-brand-orange text-white font-heading font-bold px-10 py-4 rounded-lg hover:bg-orange-600 transition-colors text-lg">
        Reserve Your Milton
      </a>
    </div>
  </section>
</BaseLayout>

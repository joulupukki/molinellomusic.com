---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Order Gamma PreQ" 
  description="Order your Gamma PreQ PCB set or parts kit."
>
  <section class="bg-brand-dark text-white py-16">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="font-heading font-extrabold text-4xl mb-2">Order Your Gamma PreQ</h1>
      <p class="text-gray-400">Complete the form below to request a PCB set or parts kit.</p>
    </div>
  </section>

  <section class="py-16 bg-brand-warm min-h-[60vh]">
    <div class="max-w-2xl mx-auto px-4">
      <div class="bg-white rounded-xl shadow-xl p-8 md:p-12">
        <form target="_blank" action="https://formsubmit.co/rpschultz13@gmail.com" method="POST" class="space-y-6">
          
          <div>
            <label class="block text-sm font-bold text-gray-700 mb-2">Full Name</label>
            <input type="text" name="name" class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-brand-orange focus:border-brand-orange" placeholder="John Doe" required>
          </div>

          <div>
            <label class="block text-sm font-bold text-gray-700 mb-2">Email Address</label>
            <input type="email" name="email" class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-brand-orange focus:border-brand-orange" placeholder="email@example.com" required>
          </div>

          <div>
            <label class="block text-sm font-bold text-gray-700 mb-2">What are you looking for?</label>
            <select name="order_type" class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-brand-orange focus:border-brand-orange" required>
              <option value="">Select an option...</option>
              <option value="PCB Set Only">PCB Set Only ($25)</option>
              <option value="Full Parts Kit">Full Parts Kit ($100)</option>
              <option value="Question/Inquiry">Just a question</option>
            </select>
          </div>

          <div>
            <label class="block text-sm font-bold text-gray-700 mb-2">Message & Payment Info</label>
            <textarea name="message" rows="5" class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-brand-orange focus:border-brand-orange" placeholder="Please include your shipping address and PayPal/Venmo handle." required></textarea>
          </div>

          <input type="text" name="_honey" style="display:none">
          <input type="hidden" name="_subject" value="New Gamma PreQ Order!">

          <button type="submit" class="w-full bg-brand-orange text-white font-heading font-bold px-8 py-4 rounded-lg hover:bg-orange-600 transition-all text-lg shadow-lg">
            Send Order Request
          </button>
        </form>
      </div>
      
      <div class="mt-8 text-center">
        <a href="/pedals/gamma-preq" class="text-brand-orange hover:underline font-medium">&larr; Back to Pedal Details</a>
      </div>
    </div>
  </section>
</BaseLayout>

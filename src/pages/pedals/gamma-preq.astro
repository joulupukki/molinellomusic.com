---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Gamma PreQ - Acoustic Guitar Preamp, EQ & Boost"
  description="The Gamma PreQ is a DIY acoustic guitar preamp, EQ, and boost pedal designed by Ryan Schultz. Plenty of clean gain, flexible EQ, and a dedicated boost."
  ogImage="/images/pedals/gamma-preq2.jpeg"
  noindex={true}
>
  <link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css"
  />

  <section class="bg-brand-dark text-white py-16 md:py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <h1 class="font-heading font-extrabold text-4xl md:text-5xl mb-3">
        Gamma PreQ
      </h1>
      <p class="text-gray-400 text-lg max-w-2xl mx-auto">
        Acoustic Guitar Preamp, EQ &amp; Boost
      </p>
    </div>
  </section>

  <section class="py-16 md:py-24">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="md:flex gap-12 items-center">

        <!-- ========================= -->
        <!-- CAROUSEL (REPLACEMENT)    -->
        <!-- ========================= -->
        <div class="md:w-3/5 mb-8 md:mb-0">
          <section class="py-4">
            <div class="relative">

              <div class="overflow-hidden rounded-xl shadow-lg bg-black/5">
                <div
                  class="flex transition-transform duration-500 ease-out"
                  id="gamma-carousel-track"
                >

                  <div class="flex-[0_0_100%] min-w-0">
                    <img src="/public/images/pedals/gamma-top-no-lights-r.PNG" alt="Gamma PreQ Top View" class="w-full h-auto object-contain" />
                  </div>

                  <div class="flex-[0_0_100%] min-w-0">
                    <img src="/public/images/pedals/gamma-off-side-r.png" alt="Gamma PreQ Side View 1" class="w-full h-auto object-contain" />
                  </div>

                  <div class="flex-[0_0_100%] min-w-0">
                    <img src="/public/images/pedals/gamma-off-side-2r.png" alt="Gamma PreQ Side View 2" class="w-full h-auto object-contain" />
                  </div>

                  <div class="flex-[0_0_100%] min-w-0">
                    <img src="/public/images/pedals/gamma-front-low-r.png" alt="Gamma PreQ Front Low" class="w-full h-auto object-contain" />
                  </div>

                  <div class="flex-[0_0_100%] min-w-0">
                    <img src="/public/images/pedals/gamma-back-r.png" alt="Gamma PreQ Back View" class="w-full h-auto object-contain" />
                  </div>

                  <div class="flex-[0_0_100%] min-w-0">
                    <img src="/public/images/pedals/gamma-inside-r.png" alt="Gamma Inside View" class="w-full h-auto object-contain" />
                  </div>

                  <div class="flex-[0_0_100%] min-w-0">
                    <img src="/public/images/pedals/gamma-boards-r.png" alt="Gamma PCB Set" class="w-full h-auto object-contain" />
                  </div>

                </div>
              </div>

              <!-- NAV -->
              <button
                id="gamma-carousel-prev"
                class="absolute left-2 top-1/2 -translate-y-1/2 w-10 h-10 flex items-center justify-center rounded-full bg-white/80 border hover:bg-orange-500 hover:text-white shadow"
              >
                ‹
              </button>

              <button
                id="gamma-carousel-next"
                class="absolute right-2 top-1/2 -translate-y-1/2 w-10 h-10 flex items-center justify-center rounded-full bg-white/80 border hover:bg-orange-500 hover:text-white shadow"
              >
                ›
              </button>

              <!-- DOTS -->
              <div class="flex justify-center gap-2 mt-4" id="gamma-carousel-dots"></div>

            </div>
          </section>
        </div>

        <!-- ========================= -->
        <!-- TEXT CONTENT              -->
        <!-- ========================= -->
        <div class="md:w-2/5">
          <h2 class="font-heading font-bold text-2xl md:text-3xl mb-4">
            Designed for Acoustic Guitar
          </h2>

          <p class="text-gray-600 text-lg mb-4 leading-relaxed">
            The Gamma PreQ was designed specifically for acoustic guitar, although it will work for any acoustic instrument (but not bass). It has plenty of clean gain as a preamp, a plethora of EQ options, and a dedicated boost.
          </p>

          <p class="text-gray-600 mb-4 leading-relaxed">
            It's quieter than most acoustic preamps and offers more EQ options. It's not as great as Grace Designs' ALiX (which is awesome), but it's close!
          </p>

          <p class="text-gray-600 leading-relaxed">
            This is a <strong>DIY assembly</strong> you put together yourself. While this shouldn't be your first build, there's nothing particularly challenging about it other than its size (~150 total parts). Read the BOM and Build Notes carefully to comprehend the scope of this project.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="py-16 md:py-24 bg-brand-warm">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <h2 class="font-heading font-bold text-3xl text-center mb-12">
        Features
      </h2>

      <div class="bg-white rounded-xl shadow-lg p-8 md:p-10">
        <ul class="space-y-3 text-gray-700 leading-relaxed">

          <li><strong>Gain, Volume, Boost:</strong> +25 dBu, +17 dBu, +6 dBu respectively
            <ul class="list-disc pl-6 mt-2 text-gray-600">
              <li>-&infin; for Gain , Volume</li>
            </ul>
          </li>

          <li>
            <strong>HPF / Notch:</strong> 68–440 Hz (Butterworth 2nd order)
          </li>

          <li><strong>Low Control:</strong> @ 100 Hz +/- 12 dB</li>

          <li><strong>High Shelf:</strong> @ 4 kHz +/- 12 dB</li>

          <li><strong>Parametric Mid:</strong> +/- 9 dB</li>

          <li><strong>Frequency Response:</strong> 68 Hz – 20 kHz</li>
          <li><strong>THD:</strong> &lt; 0.02 %</li>
          <li><strong>Input Power:</strong> &lt; 200 mA @ 9 VDC</li>
          <li><strong>Internal:</strong> +/-15 VDC</li>
          <li><strong>Input Impedance:</strong> 1 MΩ</li>
          <li><strong>Bypass:</strong> True Bypass or Mute</li>

        </ul>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="py-16 md:py-24">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">

      <h2 class="font-heading font-bold text-3xl mb-8">Pricing</h2>

      <div class="bg-white rounded-xl shadow-lg p-8 md:p-10 text-left">
        <ul class="space-y-4 text-gray-700 leading-relaxed">

          <li><strong>PCB set only</strong>: $25 + $8 shipping</li>

          <li><strong>Parts kit</strong>: $100 + $10 shipping</li>

          <li>Payment via Venmo or PayPal</li>

        </ul>
      </div>
    </div>
  </section>

  <!-- Documentation -->
  <section class="py-16 md:py-24 bg-brand-warm">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">

      <h2 class="font-heading font-bold text-3xl mb-4 text-center">
        Documentation
      </h2>

      <p class="text-gray-600 text-lg text-center mb-10">
        Reference documents for building and tuning the Gamma PreQ.
      </p>

      <div class="bg-white rounded-xl shadow-lg p-8 md:p-10">
        <ul class="space-y-4 text-gray-700">

          <li><a href="#" class="text-brand-orange font-bold">BOM & Cost Estimate</a></li>
          <li><a href="#" class="text-brand-orange font-bold">Build Notes</a></li>
          <li><a href="#" class="text-brand-orange font-bold">Circuit Notes</a></li>

        </ul>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 md:py-24">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">

      <h2 class="font-heading font-bold text-3xl mb-4">Interested?</h2>

      <p class="text-gray-600 text-lg mb-8">
        Contact us for PCB sets or kits.
      </p>

      <a
        href="/pedals/gamma-preq/order"
        class="inline-block bg-brand-orange text-white font-bold px-8 py-3 rounded-lg"
      >
        Contact Us
      </a>

    </div>
  </section>

</BaseLayout>

<!-- ========================= -->
<!-- CAROUSEL SCRIPT           -->
<!-- ========================= -->
<script>
  (function () {
    const track = document.getElementById('gamma-carousel-track');
    const prevBtn = document.getElementById('gamma-carousel-prev');
    const nextBtn = document.getElementById('gamma-carousel-next');
    const dotsContainer = document.getElementById('gamma-carousel-dots');

    if (!track) return;

    const slides = track.children;
    const total = slides.length;
    let current = 0;
    let timer;

    const dots = [];

    for (let i = 0; i < total; i++) {
      const dot = document.createElement('button');
      dot.className = 'w-2.5 h-2.5 rounded-full bg-gray-300';
      dot.onclick = () => goTo(i);
      dotsContainer.appendChild(dot);
      dots.push(dot);
    }

    function update() {
      track.style.transform = `translateX(-${current * 100}%)`;

      dots.forEach((d, i) => {
        d.classList.toggle('bg-orange-500', i === current);
        d.classList.toggle('bg-gray-300', i !== current);
      });
    }

    function goTo(i) {
      current = (i + total) % total;
      update();
      reset();
    }

    function next() {
      goTo(current + 1);
    }

    function prev() {
      goTo(current - 1);
    }

    function autoplay() {
      timer = setInterval(next, 5000);
    }

    function reset() {
      clearInterval(timer);
      autoplay();
    }

    prevBtn.onclick = prev;
    nextBtn.onclick = next;

    let startX = 0;
    track.addEventListener('touchstart', (e) => startX = e.touches[0].clientX);
    track.addEventListener('touchend', (e) => {
      const diff = startX - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 50) diff > 0 ? next() : prev();
    });

    update();
    autoplay();
  })();
</script>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Gamma PreQ - Acoustic Guitar Preamp, EQ & Boost"
  description="The Gamma PreQ is a DIY acoustic guitar preamp, EQ, and boost pedal. Plenty of clean gain, flexible EQ, and a dedicated boost."
  ogImage="/images/pedals/gamma-preq2.jpeg"
  noindex={true}
>
  <link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css"
  />

  <section class="bg-brand-dark text-white py-16 md:py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">

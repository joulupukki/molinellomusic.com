---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="AcoustiMatch - Molinello Music" description="Create impulse responses for acoustic instrument pickups so they sound like a real microphone. Standalone app and DAW plugin." ogImage="/images/acoustimatch/icon.png">
  <!-- Hero -->
  <section class="bg-brand-dark text-white py-16 md:py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <img src="/images/acoustimatch/icon.png" alt="AcoustiMatch" class="mx-auto w-28 h-28 rounded-2xl shadow-2xl mb-6" />
      <h1 class="font-heading font-extrabold text-4xl md:text-5xl mb-3">AcoustiMatch</h1>
      <p class="text-gray-400 text-lg max-w-2xl mx-auto">
        Make your acoustic instrument's pickup sound like a real microphone.
      </p>
    </div>
  </section>

  <!-- Screenshot + description -->
  <section class="py-16 md:py-24">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="md:flex gap-12 items-center">
        <div class="md:w-3/5 mb-8 md:mb-0">
          <img src="/images/acoustimatch/screenshot.png" alt="AcoustiMatch showing EQ matching curve" class="rounded-xl shadow-lg w-full" />
        </div>
        <div class="md:w-2/5">
          <h2 class="font-heading font-bold text-2xl md:text-3xl mb-4">Impulse Response Creator</h2>
          <p class="text-gray-600 text-lg mb-4 leading-relaxed">
            AcoustiMatch analyzes the tonal difference between your instrument's pickup and a microphone, then creates an impulse response (IR) that bridges the gap.
          </p>
          <p class="text-gray-600 mb-4 leading-relaxed">
            Load the IR into any convolution plugin or IR loader in your DAW, live rig, or standalone player — and your pickup will sound remarkably close to your mic'd tone.
          </p>
          <p class="text-gray-600 leading-relaxed">
            Available as a <strong>standalone app</strong> and a <strong>DAW plugin</strong> (VST3/AU/AAX).
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="py-16 md:py-24 bg-brand-warm">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <h2 class="font-heading font-bold text-3xl text-center mb-12">How It Works</h2>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="w-14 h-14 rounded-full bg-brand-dark text-white flex items-center justify-center mx-auto mb-4 font-heading font-bold text-xl">1</div>
          <h3 class="font-heading font-bold text-lg mb-2">Record</h3>
          <p class="text-gray-600">Play your instrument while AcoustiMatch captures both the pickup and microphone signals simultaneously.</p>
        </div>
        <div class="text-center">
          <div class="w-14 h-14 rounded-full bg-brand-dark text-white flex items-center justify-center mx-auto mb-4 font-heading font-bold text-xl">2</div>
          <h3 class="font-heading font-bold text-lg mb-2">Match</h3>
          <p class="text-gray-600">The app analyzes the spectral differences and computes an EQ curve that transforms one into the other.</p>
        </div>
        <div class="text-center">
          <div class="w-14 h-14 rounded-full bg-brand-dark text-white flex items-center justify-center mx-auto mb-4 font-heading font-bold text-xl">3</div>
          <h3 class="font-heading font-bold text-lg mb-2">Export IR</h3>
          <p class="text-gray-600">Export the result as a standard impulse response file you can load into any IR loader or convolution plugin.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="py-16 md:py-24">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="font-heading font-bold text-3xl mb-4">Pricing</h2>
      <p class="text-gray-600 text-lg mb-8 leading-relaxed">
        EQ matching is <strong>completely free</strong> in both the standalone app and DAW plugin. To export impulse responses, you'll need a license key.
      </p>
      <p class="text-gray-600 text-lg leading-relaxed">
        AcoustiMatch is currently in beta testing. If you'd like to get early access to the app and plugin, please <a href="/contact" class="text-brand-orange font-bold hover:underline">contact us</a>.
      </p>
    </div>
  </section>

  <!--
      <div class="bg-white rounded-xl shadow-lg p-8 max-w-md mx-auto">
        <p class="font-heading font-bold text-2xl text-brand-dark mb-2">Pay What You Want</p>
        <p class="text-gray-500 mb-1">Minimum: $2</p>
        <p class="text-gray-500 mb-6">Suggested: $20</p>
        <a
          href="https://buy.stripe.com/3cI5kDdyRbZL3nF16s8og0l"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block bg-brand-orange text-white font-heading font-bold px-8 py-3 rounded-lg hover:bg-orange-600 transition-colors text-lg"
        >
          Buy a License Key
        </a>
      </div>
  -->

  <!-- Downloads -->
  <section class="py-16 md:py-24 bg-brand-warm" id="downloads">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="font-heading font-bold text-3xl mb-4">Downloads</h2>
      <p class="text-gray-600 text-lg mb-8">
        Download the latest version of AcoustiMatch. EQ matching works immediately — a license key is only needed to export impulse responses.
      </p>
      <div class="bg-white rounded-xl shadow-lg p-8 max-w-md mx-auto">
        <p class="font-heading font-bold text-lg text-brand-dark mb-1">v1.0.2</p>
        <p class="text-gray-500 text-sm mb-6">Latest release</p>
        <a
          href="/downloads/acoustimatch/v1.0.2/AcoustiMatch-v1.0.2-mac.zip"
          class="inline-flex items-center gap-2 bg-brand-dark text-white font-heading font-bold px-6 py-3 rounded-lg hover:bg-brand-charcoal transition-colors"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M7 10l5 5m0 0l5-5m-5 5V3" /></svg>
          Mac (Universal)
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
